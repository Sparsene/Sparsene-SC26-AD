{
	"version": 1,
	"disable_existing_loggers": false,
	"formatters": {
		"standard": {
			"format": "%(asctime)s [%(levelname)s] %(name)s: %(message)s"
		},
		"detailed": {
			"format": "[%(levelname)s|%(module)s|L%(lineno)d] %(asctime)s: %(name)s: %(message)s",
			"datefmt": "%Y-%m-%dT%H:%M:%S%z"
		},
		"detailed_path": {
			"format": "[%(levelname)s|%(pathname)s|%(module)s|L%(lineno)d] %(asctime)s: %(name)s: %(message)s",
			"datefmt": "%Y-%m-%dT%H:%M:%S%z"
		}
	},
	"handlers": {
		"stdout": {
			"class": "logging.StreamHandler",
			"formatter": "standard",
			"level": "DEBUG",
			"stream": "ext://sys.stdout"
		},
		"stderr": {
			"class": "logging.StreamHandler",
			"formatter": "standard",
			"level": "WARNING",
			"stream": "ext://sys.stderr"
		}
	},
	"loggers": {
		"root": {
			"level": "INFO",
			"handlers": [
				"stdout",
				"stderr"
			]
		}
	}
}